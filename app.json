{
  "expo": {
    "scheme": "kpunimusprofileapp",
    "name": "Klinik Pratama UNIMUS",
    "slug": "kpunimus-profile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_klinik.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_klinik.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capbatu.profilekpunimus"
    },
    "android": {
      "package": "com.capbatu.profilekpunimus",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "NOTIFICATIONS"
      ],
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#0F766E"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_klinik.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "742170fe-9c05-428d-9723-416ad305e459"
      }
    }
  }
}
